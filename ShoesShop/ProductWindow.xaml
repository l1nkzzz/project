<Window x:Class="ShoesShop.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShoesShop"
        mc:Ignorable="d" Style="{StaticResource Windows}"
        WindowStartupLocation="CenterScreen"
        Title="Магазин обуви — каталог товаров" Height="800" Width="1200">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="16" Padding="20" Margin="0 0 0 16">
            <DockPanel>
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Магазин обуви" FontSize="32" FontWeight="Bold"/>
                <TextBlock Text="{Binding UserInfo}" FontSize="15" Foreground="{StaticResource MutedText}"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="AddProductButton" Content="Добавить товар" Click="AddProductButton_Click" Margin="5" IsEnabled="{Binding CanUseCart}"/>
                <Button x:Name="CartButton" Content="Корзина (0)" Click="CartButton_Click" Margin="5"/>
                <Button x:Name="LogOutButton" Content="Выйти" Click="LogOutButton_Click" Margin="5"/>
            </StackPanel>
        </DockPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="14" BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="16" Margin="0 0 0 16">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0 0 5 0"/>
                <TextBox x:Name="SearchBox" Width="260" TextChanged="SearchBox_TextChanged" Margin="0 0 15 0"/>
                <TextBlock Text="Категория:" VerticalAlignment="Center" Margin="0 0 5 0"/>
                <ComboBox x:Name="CategoryBox" Width="180" SelectionChanged="CategoryBox_SelectionChanged" Margin="0 0 15 0"/>
                <TextBlock Text="Бренд:" VerticalAlignment="Center" Margin="0 0 5 0"/>
                <ComboBox x:Name="BrandBox" Width="170" SelectionChanged="BrandBox_SelectionChanged" Margin="0 0 15 0"/>
                <TextBlock Text="Сортировка:" VerticalAlignment="Center" Margin="0 0 5 0"/>
                <ComboBox x:Name="SortBox" Width="210" SelectionChanged="SortBox_SelectionChanged"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2">
            <ItemsControl x:Name="ProductList" ItemsSource="{Binding FilteredProducts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{StaticResource Line}" BorderThickness="1" Margin="0 0 0 14" Padding="16" CornerRadius="14" Background="White">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#F3F5F8" CornerRadius="12" Padding="8">
                                    <Image Source="{Binding NewPhoto}" Height="150" Width="150" Stretch="Uniform"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="18 4 10 4">
                                    <TextBlock FontWeight="Bold" FontSize="18" TextWrapping="Wrap">
                                        <Run Text="{Binding Categories.Category}"/>
                                        <Run Text=" | "/>
                                        <Run Text="{Binding ProductType.ProductType1}"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap">
                                        <Run Text="Описание товара: "/>
                                        <Run Text="{Binding Description}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="Производитель: "/>
                                        <Run Text="{Binding Producers.Producer}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="Поставщик: "/>
                                        <Run Text="{Binding Suppliers.Supplier}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="Цена: "/>
                                        <Run Text="{Binding Price}" Foreground="{Binding DiscountPriceStyler[0]}" TextDecorations="{Binding DiscountPriceStyler[1]}" />
                                        <Run Text=" "/>
                                        <Run Text="{Binding DiscountPriceStyler[2]}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="Единица измерения: "/>
                                        <Run Text="{Binding Unit}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="Количество на складе: "/>
                                        <Run Text="{Binding QuantityInStock}"/>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <StackPanel>
                                        <Button Content="Добавить в корзину"
                                            Tag="{Binding}"
                                            Click="AddToCartButton_Click"
                                            IsEnabled="{Binding DataContext.CanUseCart, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Margin="10"/>
                                        <Button Content="Удалить"
                                            Tag="{Binding}"
                                            Click="DeleteProductButton_Click"
                                            IsEnabled="{Binding DataContext.CanUseCart, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Margin="10"
                                            Background="#E74C3C"
                                            Foreground="White"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <TextBlock Grid.Row="3" Text="{Binding ProductsCounter}" HorizontalAlignment="Right" Margin="0 10 5 0"/>
    </Grid>
</Window>
