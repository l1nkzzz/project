<Window x:Class="ShoesShop.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShoesShop"
        mc:Ignorable="d" Style="{StaticResource Windows}"
        WindowStartupLocation="CenterScreen"
        Title="Магазин обуви — каталог товаров" Height="800" Width="1200">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="16" Padding="20" Margin="0 0 0 16">
            <DockPanel>
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Магазин обуви" FontSize="32" FontWeight="Bold"/>
                <Run Text=" "/>
                                        <Run Text="{Binding DiscountPriceStyler[2]}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="Единица измерения: "/>
                                        <Run Text="{Binding Unit}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="Количество на складе: "/>
                                        <Run Text="{Binding QuantityInStock}"/>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Center" FontSize="26" FontWeight="Bold" Foreground="{StaticResource Accent}">
                                        <Run Text="{Binding Discount}"/>
                                        <Run Text="%"/>
                                    </TextBlock>
                                    <Button Content="Добавить в корзину"
                                            Tag="{Binding}"
                                            Click="AddToCartButton_Click"
                                            Margin="10"
                                            />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <TextBlock Grid.Row="3" Text="{Binding ProductsCounter}" HorizontalAlignment="Right" Margin="0 10 5 0"/>
    </Grid>
</Window>
