<Window x:Class="ShoesShop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShoesShop"
        mc:Ignorable="d" Style="{StaticResource Windows}"
        WindowStartupLocation="CenterScreen"
        Title="Авторизация" Height="460" Width="760" ResizeMode="NoResize">
    <Grid>
        <Border Width="360" Padding="32" Background="White" CornerRadius="18"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.15"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Магазин обуви" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="Вход в систему" FontSize="15" Foreground="{StaticResource MutedText}" HorizontalAlignment="Center" Margin="0 6 0 28"/>

                <TextBlock Text="Логин" Foreground="{StaticResource MutedText}" Margin="0 0 0 6"/>
                <TextBox x:Name="LoginEnter" Height="38" Margin="0 0 0 16"/>

                <TextBlock Text="Пароль" Foreground="{StaticResource MutedText}" Margin="0 0 0 6"/>
                <PasswordBox x:Name="PasswordEnter" Height="38" Margin="0 0 0 22"/>

                <Button x:Name="LoginButton" Content="Войти" Click="LoginButton_Click" Height="42"/>
                <TextBlock Text="Войти как гость" HorizontalAlignment="Center" Foreground="{StaticResource Accent}"
                           FontSize="14" FontWeight="SemiBold" Cursor="Hand" Margin="0 18 0 0"
                           MouseDown="TextBlock_MouseDown"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
